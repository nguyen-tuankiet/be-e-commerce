// =====================================================================
// GlowUp Concierge — PostgreSQL schema (paste vào dbdiagram.io)
// Author: design draft từ API Growup.pdf
// Convention: snake_case, uuid PK + code unique, money = BIGINT (VND)
// =====================================================================

Project glowup_concierge {
  database_type: 'PostgreSQL'
  Note: '''
    Marketplace dịch vụ sửa chữa.
    - Tiền tệ: VND, lưu BIGINT (không phân số).
    - Thời gian: timestamptz (UTC).
    - PK: uuid; client-facing code lưu cột `code`.
  '''
}

// ============================================================
// ENUMS
// ============================================================

Enum user_role {
  customer
  technician
  admin
}

Enum user_status {
  pending
  verified
  locked
  deleted
}

Enum verification_status {
  none
  pending
  approved
  rejected
}

Enum order_status {
  new
  assigned
  scheduled
  in_progress
  completed
  cancelled
}

Enum order_actor {
  customer
  technician
  admin
  system
}

Enum price_adjustment_status {
  pending
  approved
  rejected
}

Enum payment_method {
  wallet
  cash
  vietqr
  momo
  bank_transfer
}

Enum quotation_status {
  pending
  accepted
  rejected
  expired
}

Enum message_type {
  text
  image
  quotation
  system
}

Enum conversation_status {
  active
  archived
  closed
}

Enum warranty_status {
  pending
  in_progress
  completed
  rejected
  expired
}

Enum report_status {
  open
  investigating
  resolved
  dismissed
}

Enum report_reason {
  extra_fee
  bad_attitude
  no_show
  poor_quality
  fraud
  other
}

Enum tx_type {
  topup
  withdraw
  commission
  earning
  refund
  adjustment
  warranty_hold
}

Enum tx_status {
  pending
  awaiting_payment
  pending_verification
  success
  failed
  cancelled
}

Enum withdraw_status {
  pending
  approved
  processing
  paid
  rejected
}

Enum kyc_status {
  pending
  approved
  rejected
}

Enum category_priority {
  high
  normal
  low
}

Enum category_status {
  active
  inactive
}

Enum tech_tier {
  normal
  premium
}

Enum notification_type {
  order_new
  order_accepted
  order_rejected
  order_in_progress
  order_completed
  order_cancelled
  price_adjustment
  price_approved
  price_rejected
  message_new
  review_new
  warranty_new
  payment_success
  payment_failed
  withdraw_approved
  withdraw_rejected
  verification_approved
  verification_rejected
  system
}

Enum settings_scope {
  general
  billing
  notifications
  operations
}

Enum doc_type {
  id_front
  id_back
  portrait
  certificate
  selfie
  other
}

Enum media_folder {
  avatars
  orders
  verifications
  categories
  reviews
  warranty
  reports
  evidence
  misc
}

// ============================================================
// IDENTITY
// ============================================================

Table users {
  id              uuid          [pk, default: `gen_random_uuid()`]
  code            varchar(32)   [unique, not null, note: 'USR-001 / TECH-001 / GLW-9921']
  full_name       varchar(150)  [not null]
  email           varchar(255)  [unique]
  phone           varchar(20)   [unique]
  password_hash   varchar(255)  [not null]
  role            user_role     [not null]
  status          user_status   [not null, default: 'pending']
  avatar_url      text
  email_verified_at timestamptz
  phone_verified_at timestamptz
  last_active_at  timestamptz
  last_login_at   timestamptz
  metadata        jsonb
  created_at      timestamptz   [not null, default: `now()`]
  updated_at      timestamptz   [not null, default: `now()`]
  deleted_at      timestamptz

  Indexes {
    role
    status
    (role, status)
    (status, created_at)
  }
  // Bổ sung khi migrate (không express được trong DBML):
  //  CREATE INDEX idx_users_full_name_trgm ON users USING gin (full_name gin_trgm_ops);
  //  CREATE UNIQUE INDEX uq_users_email_active ON users(email) WHERE deleted_at IS NULL;
}

Table user_addresses {
  id            uuid          [pk, default: `gen_random_uuid()`]
  user_id       uuid          [not null, ref: > users.id]
  label         varchar(50)
  address_line  text          [not null]
  ward          varchar(100)
  district      varchar(100)
  city          varchar(100)
  latitude      decimal(9,6)
  longitude     decimal(9,6)
  is_default    boolean       [not null, default: false]
  created_at    timestamptz   [not null, default: `now()`]
  updated_at    timestamptz   [not null, default: `now()`]

  Indexes {
    user_id
    (district, city)
  }
}

Table user_devices {
  id            uuid          [pk, default: `gen_random_uuid()`]
  user_id       uuid          [not null, ref: > users.id]
  platform      varchar(20)   [not null, note: 'ios | android | web']
  push_token    text          [unique, not null]
  app_version   varchar(20)
  last_seen_at  timestamptz
  created_at    timestamptz   [not null, default: `now()`]

  Indexes { user_id }
}

Table refresh_tokens {
  id           uuid          [pk, default: `gen_random_uuid()`]
  user_id      uuid          [not null, ref: > users.id]
  token_hash   varchar(255)  [unique, not null]
  user_agent   text
  ip_address   varchar(45)
  expires_at   timestamptz   [not null]
  revoked_at   timestamptz
  replaced_by  uuid
  created_at   timestamptz   [not null, default: `now()`]

  Indexes {
    user_id
    expires_at
  }
}

Table password_reset_tokens {
  id          uuid          [pk, default: `gen_random_uuid()`]
  user_id     uuid          [not null, ref: > users.id]
  token_hash  varchar(255)  [unique, not null]
  channel     varchar(10)   [not null, note: 'sms | email']
  expires_at  timestamptz   [not null]
  used_at     timestamptz
  created_at  timestamptz   [not null, default: `now()`]

  Indexes { user_id }
}

// ============================================================
// SERVICE TAXONOMY
// ============================================================

Table service_categories {
  id           uuid              [pk, default: `gen_random_uuid()`]
  code         varchar(32)       [unique, not null, note: 'CAT-001']
  parent_id    uuid              [ref: > service_categories.id]
  title        varchar(150)      [not null]
  description  text
  icon_url     text
  priority     category_priority [not null, default: 'normal']
  status       category_status   [not null, default: 'active']
  sort_order   int               [not null, default: 0]
  created_at   timestamptz       [not null, default: `now()`]
  updated_at   timestamptz       [not null, default: `now()`]

  Indexes {
    status
    parent_id
    (status, sort_order)
  }
}

Table skills {
  id           uuid          [pk, default: `gen_random_uuid()`]
  category_id  uuid          [ref: > service_categories.id]
  name         varchar(150)  [unique, not null]
  created_at   timestamptz   [not null, default: `now()`]

  Indexes { category_id }
}

// ============================================================
// TECHNICIAN
// ============================================================

Table technician_profiles {
  user_id              uuid                 [pk, ref: > users.id]
  bio                  text
  cover_image_url      text
  primary_category_id  uuid                 [ref: > service_categories.id]
  years_experience     int
  price_per_hour       bigint
  rating_avg           decimal(3,2)         [not null, default: 0]
  rating_count         int                  [not null, default: 0]
  completed_jobs       int                  [not null, default: 0]
  cancelled_jobs       int                  [not null, default: 0]
  is_available         boolean              [not null, default: true]
  available_from       timestamptz
  tier                 tech_tier            [not null, default: 'normal']
  title_badge          varchar(100)
  verification_status  verification_status  [not null, default: 'none']
  joined_at            timestamptz          [not null, default: `now()`]
  updated_at           timestamptz          [not null, default: `now()`]

  Indexes {
    is_available
    rating_avg
    tier
    primary_category_id
    (is_available, rating_avg)
    (verification_status, tier)
  }
}

Table technician_skills {
  technician_id  uuid          [not null, ref: > technician_profiles.user_id]
  skill_id       uuid          [not null, ref: > skills.id]
  created_at     timestamptz   [not null, default: `now()`]

  Indexes {
    (technician_id, skill_id) [pk]
    skill_id
  }
}

Table technician_service_areas {
  technician_id  uuid           [not null, ref: > technician_profiles.user_id]
  district       varchar(100)   [not null]
  city           varchar(100)   [not null]
  created_at     timestamptz    [not null, default: `now()`]

  Indexes {
    (technician_id, district, city) [pk]
    (district, city)
  }
}

Table technician_schedules {
  id             uuid     [pk, default: `gen_random_uuid()`]
  technician_id  uuid     [not null, ref: > technician_profiles.user_id]
  day_of_week    int      [not null, note: '0=Sun..6=Sat']
  start_time     time
  end_time       time
  is_off         boolean  [not null, default: false]

  Indexes {
    (technician_id, day_of_week) [unique]
  }
}

// ============================================================
// ORDERS
// ============================================================

Table orders {
  id               uuid          [pk, default: `gen_random_uuid()`]
  code             varchar(32)   [unique, not null, note: 'GU-99210']
  customer_id      uuid          [not null, ref: > users.id]
  technician_id    uuid          [ref: > users.id]
  category_id      uuid          [ref: > service_categories.id]
  service_name     varchar(200)
  sub_service      varchar(200)
  device_name      varchar(200)
  description      text

  address_id       uuid          [ref: > user_addresses.id]
  address_text     text          [not null, note: 'snapshot lúc đặt']
  district         varchar(100)
  city             varchar(100)
  latitude         decimal(9,6)
  longitude        decimal(9,6)

  estimated_price  bigint        [not null, default: 0]
  final_price      bigint
  payment_method   payment_method
  warranty_months  int           [not null, default: 0]

  status           order_status  [not null, default: 'new']
  expected_at      timestamptz   [note: 'KH yêu cầu']
  scheduled_at     timestamptz   [note: 'thợ chốt lịch']
  accepted_at      timestamptz
  started_at       timestamptz
  completed_at     timestamptz
  cancelled_at     timestamptz
  cancelled_by     order_actor
  cancel_reason    text

  created_at       timestamptz   [not null, default: `now()`]
  updated_at       timestamptz   [not null, default: `now()`]
  deleted_at       timestamptz

  Indexes {
    customer_id
    technician_id
    status
    (status, created_at)
    (technician_id, status)
    (customer_id, status)
    category_id
    scheduled_at
    (status, scheduled_at)
    (district, city, status)
  }
}

Table order_status_history {
  id            uuid          [pk, default: `gen_random_uuid()`]
  order_id      uuid          [not null, ref: > orders.id]
  from_status   order_status
  to_status     order_status  [not null]
  actor_id      uuid          [ref: > users.id]
  actor_role    order_actor
  reason        text
  created_at    timestamptz   [not null, default: `now()`]

  Indexes {
    order_id
    (order_id, created_at)
  }
}

Table order_images {
  id           uuid          [pk, default: `gen_random_uuid()`]
  order_id     uuid          [not null, ref: > orders.id]
  url          text          [not null]
  kind         varchar(20)   [not null, note: 'before | completion | evidence']
  uploaded_by  uuid          [ref: > users.id]
  created_at   timestamptz   [not null, default: `now()`]

  Indexes {
    order_id
    (order_id, kind)
  }
}

Table order_price_adjustments {
  id              uuid                     [pk, default: `gen_random_uuid()`]
  order_id        uuid                     [not null, ref: > orders.id]
  original_price  bigint                   [not null]
  new_price       bigint                   [not null]
  reason          text                     [not null]
  status          price_adjustment_status  [not null, default: 'pending']
  requested_by    uuid                     [not null, ref: > users.id]
  requested_at    timestamptz              [not null, default: `now()`]
  reviewed_by     uuid                     [ref: > users.id]
  reviewed_at     timestamptz
  review_note     text

  Indexes {
    order_id
    status
    (order_id, status)
  }
}

Table order_price_adjustment_parts {
  id            uuid          [pk, default: `gen_random_uuid()`]
  adjustment_id uuid          [not null, ref: > order_price_adjustments.id]
  name          varchar(200)  [not null]
  price         bigint        [not null]
  part_code     varchar(50)
  qty           int           [not null, default: 1]

  Indexes { adjustment_id }
}

Table order_price_adjustment_evidence {
  id            uuid          [pk, default: `gen_random_uuid()`]
  adjustment_id uuid          [not null, ref: > order_price_adjustments.id]
  url           text          [not null]
  created_at    timestamptz   [not null, default: `now()`]

  Indexes { adjustment_id }
}

// ============================================================
// REVIEWS
// ============================================================

Table reviews {
  id             uuid          [pk, default: `gen_random_uuid()`]
  order_id       uuid          [unique, not null, ref: > orders.id, note: '1 đơn / 1 review']
  customer_id    uuid          [not null, ref: > users.id]
  technician_id  uuid          [not null, ref: > users.id]
  rating         int           [not null, note: 'CHECK rating BETWEEN 1 AND 5']
  content        text
  created_at     timestamptz   [not null, default: `now()`]
  updated_at     timestamptz   [not null, default: `now()`]

  Indexes {
    technician_id
    (technician_id, created_at)
    (technician_id, rating)
  }
}

Table review_images {
  id          uuid          [pk, default: `gen_random_uuid()`]
  review_id   uuid          [not null, ref: > reviews.id]
  url         text          [not null]
  created_at  timestamptz   [not null, default: `now()`]

  Indexes { review_id }
}

// ============================================================
// WARRANTY
// ============================================================

Table warranty_claims {
  id                   uuid             [pk, default: `gen_random_uuid()`]
  code                 varchar(32)      [unique, not null, note: 'WR-99200']
  order_id             uuid             [not null, ref: > orders.id]
  customer_id          uuid             [not null, ref: > users.id]
  technician_id        uuid             [ref: > users.id]
  status               warranty_status  [not null, default: 'pending']
  description          text             [not null]
  scheduled_at         timestamptz
  warranty_expires_at  timestamptz      [not null]
  resolved_at          timestamptz
  created_at           timestamptz      [not null, default: `now()`]
  updated_at           timestamptz      [not null, default: `now()`]

  Indexes {
    order_id
    customer_id
    (status, created_at)
    warranty_expires_at
  }
}

Table warranty_claim_images {
  id           uuid          [pk, default: `gen_random_uuid()`]
  warranty_id  uuid          [not null, ref: > warranty_claims.id]
  url          text          [not null]
  created_at   timestamptz   [not null, default: `now()`]

  Indexes { warranty_id }
}

// ============================================================
// REPORTS / DISPUTES
// ============================================================

Table order_reports {
  id              uuid           [pk, default: `gen_random_uuid()`]
  code            varchar(32)    [unique, not null, note: 'RPT-001']
  order_id        uuid           [not null, ref: > orders.id]
  reporter_id     uuid           [not null, ref: > users.id]
  against_id      uuid           [ref: > users.id]
  reason          report_reason  [not null]
  description     text
  status          report_status  [not null, default: 'open']
  resolved_by     uuid           [ref: > users.id]
  resolved_at     timestamptz
  resolution_note text
  created_at      timestamptz    [not null, default: `now()`]
  updated_at      timestamptz    [not null, default: `now()`]

  Indexes {
    order_id
    status
    (status, created_at)
    reporter_id
  }
}

Table order_report_evidence {
  id          uuid          [pk, default: `gen_random_uuid()`]
  report_id   uuid          [not null, ref: > order_reports.id]
  url         text          [not null]
  created_at  timestamptz   [not null, default: `now()`]

  Indexes { report_id }
}

// ============================================================
// CHAT
// ============================================================

Table conversations {
  id               uuid                [pk, default: `gen_random_uuid()`]
  code             varchar(32)         [unique, not null]
  order_id         uuid                [ref: > orders.id]
  status           conversation_status [not null, default: 'active']
  last_message_at  timestamptz
  last_message_id  uuid
  created_at       timestamptz         [not null, default: `now()`]
  updated_at       timestamptz         [not null, default: `now()`]

  Indexes {
    order_id
    last_message_at
    status
  }
  Note: 'last_message_id ref messages.id — circular FK, dùng DEFERRABLE khi migrate'
}

Table conversation_participants {
  conversation_id  uuid         [not null, ref: > conversations.id]
  user_id          uuid         [not null, ref: > users.id]
  role             user_role    [not null]
  unread_count     int          [not null, default: 0]
  last_read_at     timestamptz
  joined_at        timestamptz  [not null, default: `now()`]
  left_at          timestamptz

  Indexes {
    (conversation_id, user_id) [pk]
    user_id
  }
}

Table messages {
  id               uuid          [pk, default: `gen_random_uuid()`]
  conversation_id  uuid          [not null, ref: > conversations.id]
  sender_id        uuid          [not null, ref: > users.id]
  type             message_type  [not null, default: 'text']
  content          text
  attachment_url   text
  quotation_id     uuid          [ref: > quotations.id]
  client_msg_id    varchar(64)   [note: 'idempotency key']
  sent_at          timestamptz   [not null, default: `now()`]
  edited_at        timestamptz
  deleted_at       timestamptz

  Indexes {
    conversation_id
    (conversation_id, sent_at)
    sender_id
    (sender_id, client_msg_id) [unique, name: 'uq_msg_idempotency']
  }
}

Table message_read_receipts {
  message_id  uuid          [not null, ref: > messages.id]
  user_id     uuid          [not null, ref: > users.id]
  read_at     timestamptz   [not null, default: `now()`]

  Indexes {
    (message_id, user_id) [pk]
    user_id
  }
}

// ============================================================
// QUOTATIONS
// ============================================================

Table quotations {
  id               uuid              [pk, default: `gen_random_uuid()`]
  code             varchar(32)       [unique, not null, note: 'QUOTE-001']
  conversation_id  uuid              [not null, ref: > conversations.id]
  technician_id    uuid              [not null, ref: > users.id]
  customer_id      uuid              [not null, ref: > users.id]
  service_name     varchar(200)      [not null]
  description      text
  price            bigint            [not null]
  scheduled_at     timestamptz
  notes            text
  status           quotation_status  [not null, default: 'pending']
  order_id         uuid              [ref: > orders.id, note: 'tạo khi accept']
  expires_at       timestamptz
  accepted_at      timestamptz
  rejected_at      timestamptz
  created_at       timestamptz       [not null, default: `now()`]

  Indexes {
    conversation_id
    technician_id
    status
    (technician_id, status)
  }
}

// ============================================================
// WALLET & FINANCE
// ============================================================

Table wallets {
  user_id           uuid         [pk, ref: > users.id]
  balance           bigint       [not null, default: 0]
  pending_balance   bigint       [not null, default: 0]
  total_earned      bigint       [not null, default: 0]
  total_withdrawn   bigint       [not null, default: 0]
  currency          varchar(3)   [not null, default: 'VND']
  version           bigint       [not null, default: 0, note: 'optimistic lock']
  updated_at        timestamptz  [not null, default: `now()`]
}

Table wallet_transactions {
  id              uuid         [pk, default: `gen_random_uuid()`]
  code            varchar(40)  [unique, not null, note: 'TX-240524-01']
  wallet_user_id  uuid         [not null, ref: > wallets.user_id]
  type            tx_type      [not null]
  status          tx_status    [not null, default: 'pending']
  amount          bigint       [not null, note: '+/-, VND']
  fee             bigint       [not null, default: 0]
  net_amount      bigint       [not null]
  balance_after   bigint
  category        varchar(50)
  title           varchar(200)
  description     text
  ref_type        varchar(30)  [note: 'order | withdraw | topup | adjustment']
  ref_id          uuid
  metadata        jsonb
  created_at      timestamptz  [not null, default: `now()`]
  posted_at       timestamptz

  Indexes {
    wallet_user_id
    (wallet_user_id, created_at)
    type
    status
    (ref_type, ref_id)
    (wallet_user_id, type, status)
  }
}

Table bank_accounts {
  id                        uuid          [pk, default: `gen_random_uuid()`]
  user_id                   uuid          [not null, ref: > users.id]
  bank_name                 varchar(100)  [not null]
  bank_code                 varchar(20)
  account_number_encrypted  text          [not null]
  account_number_masked     varchar(50)   [not null]
  account_owner             varchar(150)  [not null]
  is_default                boolean       [not null, default: false]
  is_verified               boolean       [not null, default: false]
  created_at                timestamptz   [not null, default: `now()`]
  deleted_at                timestamptz

  Indexes {
    user_id
    (user_id, is_default)
  }
}

Table topup_requests {
  id                uuid          [pk, default: `gen_random_uuid()`]
  transaction_id    uuid          [ref: > wallet_transactions.id]
  user_id           uuid          [not null, ref: > users.id]
  method            varchar(30)   [not null, note: 'vietqr | momo | bank | card']
  amount            bigint        [not null]
  bank_name         varchar(100)
  account_name      varchar(150)
  account_number    varchar(50)
  transfer_content  varchar(100)  [unique, not null]
  qr_payload        text
  expires_at        timestamptz
  status            tx_status     [not null, default: 'awaiting_payment']
  paid_at           timestamptz
  verified_at       timestamptz
  created_at        timestamptz   [not null, default: `now()`]

  Indexes {
    user_id
    status
    (user_id, status)
  }
}

Table withdraw_requests {
  id              uuid             [pk, default: `gen_random_uuid()`]
  code            varchar(32)      [unique, not null, note: 'WR-001']
  transaction_id  uuid             [ref: > wallet_transactions.id]
  user_id         uuid             [not null, ref: > users.id]
  bank_account_id uuid             [not null, ref: > bank_accounts.id]
  amount          bigint           [not null]
  fee             bigint           [not null, default: 0]
  net_amount      bigint           [not null]
  status          withdraw_status  [not null, default: 'pending']
  processed_by    uuid             [ref: > users.id]
  processed_at    timestamptz
  estimated_at    timestamptz
  reject_reason   text
  created_at      timestamptz      [not null, default: `now()`]

  Indexes {
    user_id
    status
    (status, created_at)
  }
}

Table commission_settings {
  id                    uuid          [pk, default: `gen_random_uuid()`]
  platform_fee_percent  decimal(5,2)  [not null]
  vat_percent           decimal(5,2)  [not null]
  effective_from        timestamptz   [not null, default: `now()`]
  effective_to          timestamptz
  updated_by            uuid          [ref: > users.id]
  created_at            timestamptz   [not null, default: `now()`]

  Indexes {
    effective_from
    (effective_from, effective_to)
  }
}

// ============================================================
// VERIFICATION (KYC)
// ============================================================

Table verifications {
  id                       uuid          [pk, default: `gen_random_uuid()`]
  code                     varchar(32)   [unique, not null, note: 'VR-2401']
  technician_id            uuid          [not null, ref: > users.id]
  full_name_snapshot       varchar(150)  [not null]
  phone_snapshot           varchar(20)
  email_snapshot           varchar(255)
  district                 varchar(100)
  city                     varchar(100)
  service_category_id      uuid          [ref: > service_categories.id]
  service_category_text    varchar(150)
  years_experience         int
  status                   kyc_status    [not null, default: 'pending']
  note                     text
  reviewed_by              uuid          [ref: > users.id]
  reviewed_at              timestamptz
  submitted_at             timestamptz   [not null, default: `now()`]
  created_at               timestamptz   [not null, default: `now()`]

  Indexes {
    technician_id
    status
    (status, submitted_at)
  }
}

Table verification_documents {
  id              uuid          [pk, default: `gen_random_uuid()`]
  verification_id uuid          [not null, ref: > verifications.id]
  doc_type        doc_type      [not null]
  url             text          [not null]
  created_at      timestamptz   [not null, default: `now()`]

  Indexes {
    (verification_id, doc_type) [unique]
  }
}

// ============================================================
// NOTIFICATIONS
// ============================================================

Table notifications {
  id          uuid               [pk, default: `gen_random_uuid()`]
  user_id     uuid               [not null, ref: > users.id]
  type        notification_type  [not null]
  title       varchar(200)       [not null]
  body        text
  data        jsonb
  is_read     boolean            [not null, default: false]
  read_at     timestamptz
  created_at  timestamptz        [not null, default: `now()`]

  Indexes {
    user_id
    (user_id, is_read)
    (user_id, created_at)
  }
}

Table notification_preferences {
  user_id          uuid          [pk, ref: > users.id]
  new_order        boolean       [not null, default: true]
  customer_email   boolean       [not null, default: true]
  weekly_revenue   boolean       [not null, default: false]
  security_alert   boolean       [not null, default: true]
  push_enabled     boolean       [not null, default: true]
  email_enabled    boolean       [not null, default: true]
  sms_enabled      boolean       [not null, default: false]
  updated_at       timestamptz   [not null, default: `now()`]
}

// ============================================================
// ADMIN: SETTINGS, MEDIA, AUDIT
// ============================================================

Table app_settings {
  id          uuid             [pk, default: `gen_random_uuid()`]
  scope       settings_scope   [unique, not null]
  data        jsonb            [not null]
  version     int              [not null, default: 1]
  updated_by  uuid             [ref: > users.id]
  updated_at  timestamptz      [not null, default: `now()`]
}

Table media_files {
  id          uuid          [pk, default: `gen_random_uuid()`]
  uploader_id uuid          [ref: > users.id]
  folder      media_folder  [not null]
  url         text          [not null]
  filename    varchar(255)
  mime_type   varchar(50)
  size_bytes  bigint
  ref_type    varchar(30)
  ref_id      uuid
  created_at  timestamptz   [not null, default: `now()`]
  deleted_at  timestamptz

  Indexes {
    uploader_id
    (ref_type, ref_id)
    folder
  }
}

Table audit_logs {
  id          uuid          [pk, default: `gen_random_uuid()`]
  actor_id    uuid          [ref: > users.id]
  action      varchar(80)   [not null, note: 'wallet.adjust, verification.approve, ...']
  target_type varchar(40)
  target_id   uuid
  before      jsonb
  after       jsonb
  ip_address  varchar(45)
  user_agent  text
  created_at  timestamptz   [not null, default: `now()`]

  Indexes {
    actor_id
    (target_type, target_id)
    action
    created_at
  }
}
